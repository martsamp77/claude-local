{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(where:*)",
      "Bash(which:*)",
      "Bash(cat:*)",
      "Bash(type:*)",
      "PowerShell(Get-*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(Resolve-Path:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(Select-String:*)",
      "PowerShell(wsl git status:*)",
      "PowerShell(wsl git diff:*)",
      "PowerShell(wsl git log:*)",
      "PowerShell(wsl git show:*)",
      "PowerShell(wsl git branch:*)",
      "PowerShell(wsl.exe git status:*)",
      "PowerShell(wsl.exe git diff:*)",
      "PowerShell(wsl.exe git log:*)",
      "PowerShell(wsl.exe git show:*)",
      "PowerShell(wsl.exe git branch:*)",
      "PowerShell(wsl ls:*)",
      "PowerShell(wsl pwd:*)",
      "PowerShell(wsl.exe ls:*)",
      "PowerShell(wsl.exe pwd:*)",
      "PowerShell(wsl * git status:*)",
      "PowerShell(wsl * git diff:*)",
      "PowerShell(wsl * git log:*)",
      "PowerShell(wsl * git show:*)",
      "PowerShell(wsl * git branch:*)",
      "PowerShell(wsl.exe * git status:*)",
      "PowerShell(wsl.exe * git diff:*)",
      "PowerShell(wsl.exe * git log:*)",
      "PowerShell(wsl.exe * git show:*)",
      "PowerShell(wsl.exe * git branch:*)"
    ],
    "ask": [
      "Edit",
      "Write",
      "NotebookEdit",
      "Bash",
      "PowerShell"
    ]
  }
}
